{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/style.css",
    "src/**/*.tsx",
    "src/global.d.ts",
    "src/module.ts"
  ],
  "exclude": [
    "src/index.tsx",
    "src/App.tsx",
    "src/reportWebVitals.ts",
    "src/setupTests.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*-teste.tsx",
    "src/example/"
  ]
}
